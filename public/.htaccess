# InfinityFree Ultra-Safe .htaccess
RewriteEngine On
RewriteBase /

# 1. Allow existing files and directories to be accessed directly
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# 2. Redirect everything else to index.php with the query string
# Some InfinityFree servers prefer the "?" after index.php
RewriteRule ^(.*)$ index.php?/$1 [L,QSA]
